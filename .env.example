# Shared runtime
# Vercel/Supabase production: prefira o pooler transaction mode (:6543)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/estoque_cdd
PORT=3001
FRONTEND_PORT=5173

# Frontend
VITE_API_BASE_URL=http://127.0.0.1:3001
VITE_AUTH_MODE=hybrid
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend / serverless
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_UPLOAD_BUCKET=app-uploads
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SESSION_SECRET=replace-this-during-transition

# Optional bootstrap for first admin user
ADMIN_EMAIL=admin@cdd-maceio.com
ADMIN_PASSWORD=change-me-before-production
ADMIN_NAME=Administrador
ADMIN_AUTH_USER_ID=
